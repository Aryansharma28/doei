{
  "mcpServers": {
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp?project_ref=YOUR_PROJECT_REF",
      "headers": {
        "Authorization": "Bearer sbp_YOUR_SUPABASE_PERSONAL_ACCESS_TOKEN"
      }
    },
    "langwatch": {
      "command": "npx",
      "args": ["-y", "@langwatch/mcp-server"],
      "env": {
        "LANGWATCH_API_KEY": "sk-lw-YOUR_LANGWATCH_API_KEY"
      }
    }
  }
}
