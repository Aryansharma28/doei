# Copy this file to .env (and .env.local for Vite if you prefer) and fill in
# the values for the services you want to enable. Variables prefixed with
# VITE_ are exposed to the browser by Vite.

# -----------------------------------------------------------------------------
# Supabase (required)
# -----------------------------------------------------------------------------
# Create a project at https://supabase.com and apply the SQL files in /supabase
# to provision the tables. The anon key is safe for the browser as long as
# Row Level Security is enabled.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Used by backend/server.ts, voice-agent, and the seed scripts. The
# service-role key bypasses RLS — keep it server-side only.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -----------------------------------------------------------------------------
# Supabase MCP (optional — only if you want the backend MCP integration)
# -----------------------------------------------------------------------------
# Personal access token from https://supabase.com/dashboard/account/tokens
SUPABASE_MCP_TOKEN=
# Your project ref (the subdomain part of your supabase.co URL)
SUPABASE_PROJECT_REF=

# -----------------------------------------------------------------------------
# Gmail OAuth (optional — enables the Gmail sync + voice-agent Gmail tool)
# -----------------------------------------------------------------------------
# Create credentials at https://console.cloud.google.com -> APIs & Services
# -> Credentials -> OAuth client (Web application). Add an authorized redirect
# URI for /api/gmail/callback.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
# Default Gmail search query used by the sync job
GMAIL_MCP_QUERY=newer_than:1d

# -----------------------------------------------------------------------------
# LiveKit (required for the voice-call feature)
# -----------------------------------------------------------------------------
# Create a project at https://livekit.io
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# -----------------------------------------------------------------------------
# Voice-agent providers (required to actually run voice-agent/agent.py)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=

# Public URL of the app the voice agent should link to in summaries
APP_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# LangWatch (optional — observability)
# -----------------------------------------------------------------------------
VITE_LANGWATCH_API_KEY=
VITE_LANGWATCH_ENDPOINT=https://app.langwatch.ai

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------
PORT=3001

# Secret used to authenticate the Vercel cron job that triggers Gmail sync.
# Generate any random string and configure it in your cron caller.
CRON_SECRET=
